# nanogpt / OpenRouter — LLM через OpenAI-совместимый API
NANO_GPT_API_KEY=sk-...
NANO_GPT_BASE_URL=https://openrouter.ai/api/v1
NANO_GPT_MODEL=openai/gpt-4.1-mini

# Obsidian — путь к хранилищу заметок
# Локально: /Users/you/vault
# В Docker: /vault (путь внутри контейнера, mount задаётся в docker-compose.yml)
OBSIDIAN_VAULT=/path/to/obsidian/vault

# QDRANT_URL — только для переопределения через env (например в docker-compose)
# По умолчанию берётся из config.yaml (qdrant.url)
# QDRANT_URL=http://qdrant:6333

# WebDAV — пароль для Remotely Save (логин: obsidian)
WEBDAV_PASSWORD=changeme

# Telegram Bot (опционально)
TELEGRAM_BOT_TOKEN=

# RAGAS-оценка (опционально)
# RAGAS_JUDGE_API_KEY=sk-...
# RAGAS_JUDGE_MODEL=openai/gpt-4o-mini
